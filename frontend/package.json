{
	"name": "shokudo-nexus-frontend",
	"version": "0.1.0",
	"type": "module",
	"scripts": {
		"dev": "vite",
		"build": "tsc && vite build",
		"preview": "vite preview",
		"test": "vitest run",
		"test:watch": "vitest",
		"test:coverage": "vitest run --coverage",
		"lint": "oxlint . && biome check .",
		"lint:fix": "oxlint --fix . && biome check --write .",
		"format": "biome format --write .",
		"typecheck": "tsc --noEmit",
		"check": "npm run format && npm run lint && npm run typecheck && npm run test && npm run build"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.0",
		"@playwright/test": "^1.45.0",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^4.7.0",
		"@vitest/coverage-v8": "^2.1.0",
		"jsdom": "^29.0.1",
		"oxlint": "^0.12.0",
		"typescript": "^5.7.0",
		"vite": "^6.0.0",
		"vitest": "^2.1.0"
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"dependencies": {
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router-dom": "^7.13.2"
	}
}
